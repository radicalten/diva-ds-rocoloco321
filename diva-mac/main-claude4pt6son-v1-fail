static void print_fit(const char *s, int width) {
    int w = 0;
    while (*s && w < width) {
        unsigned char c = (unsigned char)*s;
        /* simple: count printable bytes, skip ANSI */
        if (c == 0x1b) {
            /* skip escape sequence */
            s++;
            if (*s == '[') {
                s++;
                while (*s && *s != 'm') s++;
                if (*s) s++;
            }
            continue;
        }
        putchar(*s++);
        w++;
    }
    while (w++ < width) putchar(' ');
